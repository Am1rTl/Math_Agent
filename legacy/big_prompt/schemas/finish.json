{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinishAction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "payload"
  ],
  "properties": {
    "type": {
      "const": "FINISH"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "answer",
        "values",
        "trace_id"
      ],
      "properties": {
        "answer": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "minItems": 1
              }
            ]
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "reasoning": {
          "type": "string"
        },
        "units": {
          "type": [
            "string",
            "null"
          ]
        },
        "trace_id": {
          "type": "string",
          "minLength": 6
        }
      }
    }
  }
}
